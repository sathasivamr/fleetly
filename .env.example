# Traccar backend URL (used by the Vite dev proxy for /api and /api/socket in `npm run dev`).
# Examples: https://demo.traccar.org | https://traccar.example.com
VITE_TRACCAR_URL=https://demo.traccar.org

# Optional: if you serve this SPA under a subpath (e.g. https://domain.com/fleet/), set:
# VITE_BASE_PATH=/fleet

# --- Static hosting (Firebase, AWS Lightsail, nginx) ---
# npm run build              → output in dist/
# npm run build:lightsail    → output in lightsail-publish/ (copy that folder to your server)
# Set VITE_TRACCAR_URL at build time. Traccar must allow CORS for your site origin and wss://…/api/socket.
# Firebase / cross-origin: Traccar server needs web.origin (both *.web.app + *.firebaseapp.com) and
# web.sameSiteCookie=None — see firebase-hosting.md.

# --- Optional: commercial / private orders REST API (Logistics) ---
# Base URL only (no trailing slash). Implements JSON REST: GET/POST /orders, PUT/DELETE /orders/:id
# Leave unset to use Firebase (if configured) or browser demo data (localStorage).
# VITE_LOGISTICS_API_URL=https://api.example.com

# --- Firebase SDK (Logistics & Route Planning) ---
# Get these from Firebase Console → Project Settings → Your App.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
