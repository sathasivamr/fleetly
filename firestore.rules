rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Logistics orders — authenticated users can read/write
    match /logistics_orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    // Route plans — authenticated users can read/write
    match /route_plans/{planId} {
      allow read, write: if request.auth != null;
    }
  }
}
